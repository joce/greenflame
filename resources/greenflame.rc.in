#define IDR_GREENFLAME_CURSOR_TOOL_GLYPH 115
IDR_GREENFLAME_CURSOR_TOOL_GLYPH RCDATA "@GREENFLAME_CURSOR_TOOL_GLYPH_PATH@"

#define IDR_GREENFLAME_PIN_TOOL_GLYPH 116
IDR_GREENFLAME_PIN_TOOL_GLYPH RCDATA "@GREENFLAME_PIN_TOOL_GLYPH_PATH@"

#define IDD_GREENFLAME_ABOUT 101
#define IDC_GREENFLAME_ABOUT_ICON 1001

IDD_GREENFLAME_ABOUT DIALOGEX 0, 0, 210, 86
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About Greenflame"
FONT 9, "Segoe UI"
BEGIN
    ICON "", IDC_GREENFLAME_ABOUT_ICON, 8, 8, 36, 36, SS_ICON | SS_REALSIZEIMAGE
    LTEXT "@GREENFLAME_FILE_DESCRIPTION@", -1, 52, 10, 150, 8
    LTEXT "Version @GREENFLAME_PRODUCT_VERSION@", -1, 52, 22, 150, 8
    LTEXT "@GREENFLAME_COPYRIGHT@", -1, 52, 34, 150, 16
    DEFPUSHBUTTON "OK", IDOK, 81, 64, 48, 14
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @GREENFLAME_FILE_VERSION_COMMA@
 PRODUCTVERSION @GREENFLAME_FILE_VERSION_COMMA@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "@GREENFLAME_COMPANY_NAME@\0"
            VALUE "FileDescription", "@GREENFLAME_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@GREENFLAME_FILE_VERSION_DOTTED@\0"
            VALUE "InternalName", "@GREENFLAME_INTERNAL_NAME@\0"
            VALUE "LegalCopyright", "@GREENFLAME_COPYRIGHT@\0"
            VALUE "OriginalFilename", "@GREENFLAME_ORIGINAL_FILENAME@\0"
            VALUE "ProductName", "@GREENFLAME_PRODUCT_NAME@\0"
            VALUE "ProductVersion", "@GREENFLAME_PRODUCT_VERSION@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
